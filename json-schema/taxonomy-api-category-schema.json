  "title": "Category",
  "description": "Category schema from Amplitude Taxonomy API",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "The unique identifier of the category."
    },
    "name": {
      "type": "string",
      "description": "The name of the category."
    }
  }
