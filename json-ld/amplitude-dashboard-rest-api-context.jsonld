{
  "@context": {
    "@version": 1.1,
    "amplitude": "https://amplitude.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "EventListResult": "amplitude:EventListResult",
    "UserSearchResult": "amplitude:UserSearchResult",
    "UserActivityResult": "amplitude:UserActivityResult",
    "FunnelResult": "amplitude:FunnelResult",
    "RetentionResult": "amplitude:RetentionResult",
    "SegmentationResult": "amplitude:SegmentationResult",
    "data": {
      "@id": "amplitude:data",
      "@type": "@id"
    },
    "name": "schema:name",
    "totals": {
      "@id": "amplitude:totals",
      "@type": "xsd:integer"
    },
    "matches": {
      "@id": "amplitude:matches",
      "@container": "@set",
      "@type": "@id"
    },
    "userId": {
      "@id": "amplitude:user_id",
      "@type": "xsd:string"
    },
    "amplitudeId": {
      "@id": "amplitude:amplitude_id",
      "@type": "xsd:integer"
    },
    "userData": {
      "@id": "amplitude:userData",
      "@type": "@id"
    },
    "events": {
      "@id": "amplitude:events",
      "@container": "@set",
      "@type": "@id"
    },
    "series": {
      "@id": "amplitude:series",
      "@container": "@set",
      "@type": "@id"
    },
    "seriesLabels": {
      "@id": "amplitude:seriesLabels",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "xValues": {
      "@id": "amplitude:xValues",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}