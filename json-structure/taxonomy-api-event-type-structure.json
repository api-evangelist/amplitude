{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amplitude/refs/heads/main/json-structure/taxonomy-api-event-type-structure.json",
  "name": "EventType",
  "description": "EventType schema from Amplitude Taxonomy API",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "description": "The name of the event type."
    },
    "category": {
      "type": "object",
      "properties": {
        "id": {
          "type": "int32",
          "description": "The unique identifier of the category."
        },
        "name": {
          "type": "string",
          "description": "The name of the category."
        }
      }
    },
    "description": {
      "type": "string",
      "description": "A description of the event type."
    }
  }
}